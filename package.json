{
  "name": "pocketcoder",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.8.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
